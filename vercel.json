{
  "headers": [
    {
      "source": "/fulbrightmap",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/experience/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/project-images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/seo/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "index, follow, max-image-preview:large"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, stale-while-revalidate=86400"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/chatgpt-lab",
      "destination": "/projects/fulbright-focus-group-sponsored-by-openai",
      "permanent": true
    },
    {
      "source": "/fulbright-chatgpt-lab",
      "destination": "/projects/fulbright-focus-group-sponsored-by-openai",
      "permanent": true
    },
    {
      "source": "/openai-education",
      "destination": "/projects/fulbright-focus-group-sponsored-by-openai",
      "permanent": true
    },
    {
      "source": "/chatgpt-for-education",
      "destination": "/projects/fulbright-focus-group-sponsored-by-openai",
      "permanent": true
    },
    {
      "source": "/ai-state-government-index",
      "destination": "/projects/artificial-intelligence-in-state-government-index",
      "permanent": true
    },
    {
      "source": "/ai-government-index",
      "destination": "/projects/artificial-intelligence-in-state-government-index",
      "permanent": true
    },
    {
      "source": "/ai-journalism-research",
      "destination": "/projects/senior-thesis-local-journalism",
      "permanent": true
    },
    {
      "source": "/resume",
      "destination": "/experience",
      "permanent": true
    },
    {
      "source": "/work",
      "destination": "/projects",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/fulbrightmap",
      "destination": "/index.html"
    },
    {
      "source": "/strike-tracker",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/*.ts": {
      "includeFiles": "knowledge/**"
    }
  }
}
